{
  "name": "@prisma-events/dids-schemas",
  "version": "0.0.0",
  "description": "[EXPERIMENTAL] VC credential schemas and registry for Prisma DIDs",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/prisma/prisma-dids.git",
    "directory": "packages/schemas"
  },
  "keywords": [
    "cardano",
    "verifiable-credentials",
    "zod",
    "did"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  }
}
