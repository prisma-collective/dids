{
  "name": "@prisma-events/dids-sdk",
  "version": "0.0.0",
  "description": "[EXPERIMENTAL] Core SDK for Prisma DIDs — DID lifecycle, VC issuance, Cardano anchoring",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/prisma/prisma-dids.git",
    "directory": "packages/sdk"
  },
  "keywords": [
    "cardano",
    "did",
    "w3c",
    "cip-30",
    "verifiable-credentials"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "default": "./dist/browser.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    }
  },
  "scripts": {
    "build": "node -e \"const fs=require('fs');fs.rmSync('dist',{recursive:true,force:true});try{fs.unlinkSync('tsconfig.tsbuildinfo')}catch(e){}\" && tsc",
    "dev": "tsc --watch",
    "test": "vitest src",
    "test:coverage": "vitest run src --coverage",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@emurgo/cardano-serialization-lib-browser": "^15.0.3",
    "@emurgo/cardano-serialization-lib-nodejs": "^15.0.3",
    "@noble/ed25519": "^3.0.0",
    "@prisma-events/dids-schemas": "workspace:^",
    "@prisma-events/dids-types": "workspace:^",
    "axios": "^1.7.9",
    "bs58": "^6.0.0",
    "cborg": "^4.5.8",
    "lucid-cardano": "^0.10.7"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.13",
    "typescript": "^5.7.2",
    "vitest": "^4.0.13"
  }
}
