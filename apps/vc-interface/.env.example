# =============================================================================
# VC Interface — Environment Variables
# =============================================================================
# These override the values in config/org-config.ts at deployment time.
# Copy this file to .env.local and fill in your values.
#
# For full customization (theme, credential types, issuer DIDs),
# modify config/org-config.ts directly — see comments there.
# =============================================================================

# Your organization's VC Indexer endpoint
# Overrides: org-config.ts → INDEXER_ENDPOINT
NEXT_PUBLIC_VC_INDEXER_ENDPOINT=https://your-vc-indexer.example.com

# Global DID Indexer (Prisma-operated, usually unchanged)
# Overrides: org-config.ts → DID_INDEXER_ENDPOINT
NEXT_PUBLIC_DID_INDEXER_ENDPOINT=https://did-indexer.prisma-dids.io

# Cardano network: preprod | mainnet
# Overrides: org-config.ts → NETWORK
NEXT_PUBLIC_NETWORK=preprod

# Blockfrost API key (required for on-chain anchoring: issuance, revocation)
# Get one at https://blockfrost.io — must match the NETWORK above
NEXT_PUBLIC_BLOCKFROST_API_KEY=preprodXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Pinata JWT (required for IPFS credential pinning at issuance)
# Get one at https://pinata.cloud — same account as DID Dashboard
NEXT_PUBLIC_PINATA_JWT=your-pinata-jwt
