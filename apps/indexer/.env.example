# =============================================================================
# Prisma DIDs Indexer — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# =============================================================================

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:test@localhost:5432/prisma_dids

# Blockfrost API key — must match the NETWORK below
# Get one at https://blockfrost.io
BLOCKFROST_API_KEY=preprodXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Cardano network: preprod | mainnet
NETWORK=preprod

# Indexer config: which indexer to run
#   "did"             — DID Document indexer (label 199674)
#   "vc"              — VC lifecycle event indexer (label 199675)
#   "alj-vc-indexer"  — ALJ pilot VC indexer (same label, separate deployment)
INDEXER_CONFIG=did

# Server
PORT=3001
HOST=0.0.0.0

# Polling interval in milliseconds (default 30000)
POLL_INTERVAL_MS=30000

# Confirmation depth: blocks behind chain tip before event is confirmed
# Default 112 for mainnet (NeoPRISM standard), 10 for preprod
CONFIRMATION_DEPTH=10
