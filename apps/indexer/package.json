{
  "name": "@prisma-dids/indexer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @prisma-dids/types build && pnpm --filter @prisma-dids/schemas build && pnpm --filter @prisma-dids/sdk build && tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest src",
    "type-check": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@prisma-dids/types": "workspace:*",
    "@prisma-dids/schemas": "workspace:*",
    "@prisma-dids/sdk": "workspace:*",
    "fastify": "^5.3.3",
    "@fastify/cors": "^11.0.1",
    "drizzle-orm": "^0.44.2",
    "pg": "^8.16.0",
    "zod": "^3.25.67",
    "pino": "^9.7.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "tsx": "^4.20.3",
    "drizzle-kit": "^0.31.4",
    "@types/pg": "^8.15.4",
    "vitest": "^4.0.13",
    "@vitest/coverage-v8": "^4.0.13"
  }
}
