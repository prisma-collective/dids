{
  "name": "@prisma-events/dids-indexer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @prisma-events/dids-types build && pnpm --filter @prisma-events/dids-schemas build && pnpm --filter @prisma-events/dids-sdk build && tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest src",
    "test:coverage": "vitest run src --coverage",
    "type-check": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@fastify/compress": "^8.3.1",
    "@fastify/cors": "^11.0.1",
    "@prisma-events/dids-schemas": "workspace:*",
    "@prisma-events/dids-sdk": "workspace:*",
    "@prisma-events/dids-types": "workspace:*",
    "drizzle-orm": "^0.44.2",
    "fastify": "^5.3.3",
    "pg": "^8.16.0",
    "pino": "^9.7.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/pg": "^8.15.4",
    "@vitest/coverage-v8": "^4.0.13",
    "drizzle-kit": "^0.31.4",
    "tsx": "^4.20.3",
    "typescript": "^5.7.2",
    "vitest": "^4.0.13"
  }
}
