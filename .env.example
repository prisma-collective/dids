# Prisma DIDs Configuration

# Blockfrost API keys (required for transaction submission)
# Get your keys at https://blockfrost.io
BLOCKFROST_PREPROD_KEY=preprod_your_key_here
BLOCKFROST_MAINNET_KEY=mainnet_your_key_here

# Pinata IPFS API credentials (required for DID Document storage)
# Get your keys at https://pinata.cloud
NEXT_PUBLIC_PINATA_API_KEY=your_pinata_api_key
NEXT_PUBLIC_PINATA_API_SECRET=your_pinata_api_secret

# Default network (preprod or mainnet)
NEXT_PUBLIC_DEFAULT_NETWORK=preprod
